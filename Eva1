":["## Ejemplos de predicción\n","\n","Se presentan ejemplos de predicciones utilizando el modelo base, con el objetivo de ilustrar su funcionamiento en datos nuevos."]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"cc6e9ecd","executionInfo":{"status":"ok","timestamp":1776291008416,"user_tz":240,"elapsed":440,"user":{"displayName":"FRANCISCA NICOL CASTRO PEREZ","userId":"15234580607759488458"}},"outputId":"755ede80-87d5-4401-d4d1-57f3ff17e778"},"source":["def predict_sentiment(review_text):\n","    # Limpiar el texto de la reseña\n","    cleaned_review = limpiar_texto(review_text)\n","    # Convertir el texto a secuencia numérica usando el tokenizer entrenado\n","    sequence = tokenizer.texts_to_sequences([cleaned_review])\n","    # Aplicar padding para que tenga la misma longitud que los datos de entrenamiento\n","    padded_sequence = pad_sequences(sequence, maxlen=200)\n","    # Realizar la predicción con el modelo base\n","    prediction = model_base.predict(padded_sequence)[0][0]\n","\n","    sentiment = 'Positivo' if prediction > 0.5 else 'Negativo'\n","    return sentiment, prediction\n","\n","# Ejemplos de predicciones\n","review1 = \"This movie was absolutely fantastic! I loved every minute of it.\"\n","sentiment1, prob1 = predict_sentiment(review1)\n","print(f\"Reseña: '{review1}'\\nSentimiento predicho: {sentiment1} (Probabilidad: {prob1:.4f})\\n\")\n","\n","review2 = \"What a terrible film. I wasted two hours of my life.\"\n","sentiment2, prob2 = predict_sentiment(review2)\n","print(f\"Reseña: '{review2}'\\nSentimiento predicho: {sentiment2} (Probabilidad: {prob2:.4f})\\n\")\n","\n","review3 = \"It was okay, not great, not bad, just average.\"\n","sentiment3, prob3 = predict_sentiment(review3)\n","print(f\"Reseña: '{review3}'\\nSentimiento predicho: {sentiment3} (Probabilidad: {prob3:.4f})\\n\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u001b[0m \u001b[32m━━━━